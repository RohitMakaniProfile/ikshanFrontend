{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/v1/(.*)", "destination": "http://34.60.238.78:8000/api/v1/$1" },
    { "source": "/api/(.*)", "destination": "http://34.60.238.78:8000/api/$1" },
    { "source": "/playbook/(.*)", "destination": "http://34.60.238.78:8000/playbook/$1" },
    { "source": "/growth/(.*)", "destination": "http://34.60.238.78:8001/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
